{
  "entities": {
    "Organization": {
      "title": "Organization",
      "description": "An agency or organization using the CRM.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string", "description": "UID of the user who created it" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "Invite": {
      "title": "Invite",
      "description": "An invitation for a user to join an organization.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "orgId": { "type": "string" },
        "role": { "type": "string", "enum": ["org_admin", "agent"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "orgId", "role", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the CRM (e.g., travel agent, admin).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "org_admin", "agent"] },
        "orgId": { "type": "string", "description": "ID of the organization they belong to" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A travel agency lead from Meta Ads or other sources.",
      "type": "object",
      "properties": {
        "orgId": { "type": "string", "description": "ID of the organization this lead belongs to" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "source": { "type": "string", "description": "e.g., Meta Form, Google Sheet" },
        "sourceId": { "type": "string", "description": "External ID from the source" },
        "pax": { "type": "number", "description": "Number of passengers" },
        "travelDate": { "type": "string", "description": "Expected travel date or timeframe" },
        "status": { 
          "type": "string", 
          "enum": [
            "New Enquiry", "Call Not Picked", "Call me later", "Contacted", 
            "Qualified", "Negotiating", "Awaiting Payment", "Booked", 
            "Lost & Closed", "Future Prospect", "Just Checking"
          ] 
        },
        "category": { 
          "type": "string", 
          "enum": ["Hot", "Warm", "Cold", "Repeating Customer", "Group", "None"] 
        },
        "assigneeId": { "type": "string", "description": "UID of the assigned agent" },
        "latestRemark": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orgId", "name", "phone", "status", "createdAt", "updatedAt"]
    },
    "Remark": {
      "title": "Remark",
      "description": "A note or remark added to a lead.",
      "type": "object",
      "properties": {
        "orgId": { "type": "string", "description": "ID of the organization this remark belongs to" },
        "leadId": { "type": "string" },
        "text": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orgId", "leadId", "text", "authorId", "createdAt"]
    },
    "WebsiteSettings": {
      "title": "WebsiteSettings",
      "description": "Settings for the organization's public website.",
      "type": "object",
      "properties": {
        "orgId": { "type": "string" },
        "themeColor": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroImage": { "type": "string" },
        "cloudinaryCloudName": { "type": "string" },
        "cloudinaryUploadPreset": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orgId", "updatedAt"]
    },
    "Package": {
      "title": "Package",
      "description": "A travel package offered by the organization.",
      "type": "object",
      "properties": {
        "orgId": { "type": "string" },
        "title": { "type": "string" },
        "destination": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "priceDouble": { "type": "number" },
        "priceTriple": { "type": "number" },
        "priceQuad": { "type": "number" },
        "duration": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orgId", "title", "destination", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A booking for a travel package.",
      "type": "object",
      "properties": {
        "orgId": { "type": "string" },
        "packageId": { "type": "string" },
        "packageTitle": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "travelDate": { "type": "string" },
        "paxDouble": { "type": "number" },
        "paxTriple": { "type": "number" },
        "paxQuad": { "type": "number" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Cancelled"] },
        "source": { "type": "string", "enum": ["Website", "CRM"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orgId", "packageId", "customerName", "customerPhone", "status", "createdAt"]
    }
  },
  "firestore": {
    "organizations/{orgId}": {
      "schema": { "$ref": "#/entities/Organization" },
      "description": "Stores organizations/agencies."
    },
    "invites/{inviteId}": {
      "schema": { "$ref": "#/entities/Invite" },
      "description": "Stores pending invites."
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "leads/{leadId}": {
      "schema": { "$ref": "#/entities/Lead" },
      "description": "Stores all leads."
    },
    "remarks/{remarkId}": {
      "schema": { "$ref": "#/entities/Remark" },
      "description": "Stores remarks for leads."
    },
    "website_settings/{orgId}": {
      "schema": { "$ref": "#/entities/WebsiteSettings" },
      "description": "Stores website settings for organizations."
    },
    "packages/{packageId}": {
      "schema": { "$ref": "#/entities/Package" },
      "description": "Stores travel packages."
    },
    "bookings/{bookingId}": {
      "schema": { "$ref": "#/entities/Booking" },
      "description": "Stores package bookings."
    }
  }
}
