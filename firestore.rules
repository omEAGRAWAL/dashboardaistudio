rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAgency() {
      return isSignedIn() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'agency'
      );
    }

    // Users: owner or admin only
    match /users/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // Categories: public read, admin write
    match /categories/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Products: public read for active, admin full access
    match /products/{id} {
      allow read: if resource.data.active == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Orders: customer creates own, reads own; admin reads/updates all
    match /orders/{id} {
      allow create: if isSignedIn();
      allow read: if isOwner(resource.data.customerId) || isAdmin();
      allow update: if isAdmin()
        || (isOwner(resource.data.customerId)
            && request.resource.data.status == 'cancelled'
            && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // Website settings: signed-in agency write, public read
    match /website_settings/{orgId} {
      allow read: if true;
      allow write: if isAgency();
    }

    // Campaign settings: signed-in agency write, public read
    match /campaign_settings/{orgId} {
      allow read: if true;
      allow write: if isAgency();
    }

    // Packages: public read, agency write
    match /packages/{id} {
      allow read: if true;
      allow create, update, delete: if isAgency();
    }

    // Bookings: anyone can create (public booking flow), agency can manage
    match /bookings/{id} {
      allow create: if true;
      allow read, update, delete: if isAgency();
    }

    // Campaigns: public read, agency write
    match /campaigns/{id} {
      allow read: if true;
      allow create, update, delete: if isAgency();
    }

    // Employees: agency/admin only
    match /employees/{id} {
      allow read, write: if isAgency();
    }

    // Leads: agency/admin only
    match /leads/{id} {
      allow read, write: if isAgency();
    }
  }
}
