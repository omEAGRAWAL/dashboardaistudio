# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ── Email Notifications (SMTP) ────────────────────────────────────────────────
# Your SMTP server credentials for sending lead assignment emails.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
#   Use an App Password (not your real password): myaccount.google.com/apppasswords
#
# Outlook/Office365:
#   SMTP_HOST=smtp.office365.com  SMTP_PORT=587  SMTP_SECURE=false
#
# Custom mail server (cPanel, Zoho, etc.):
#   SMTP_HOST=mail.yourdomain.com  SMTP_PORT=465  SMTP_SECURE=true
#
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="you@yourdomain.com"
SMTP_PASS="your_smtp_password_or_app_password"
SMTP_FROM="Yatrik CRM <you@yourdomain.com>"

# NEXT_PUBLIC_APP_URL: Your deployed app URL, used for the "Open CRM" button in emails.
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── Twilio (WhatsApp Chatbot & Inbox) ─────────────────────────────────────────
# Get these from https://console.twilio.com → Account → API Keys
# TWILIO_ACCOUNT_SID starts with "AC..."
# TWILIO_AUTH_TOKEN is shown on the Twilio Console dashboard
#
# Each travel agency needs a Twilio WhatsApp-enabled phone number assigned by you (superadmin).
# Use the POST /api/admin/assign-whatsapp-number endpoint to assign numbers.
# Webhook URL to set in Twilio: https://your-app.vercel.app/api/webhooks/whatsapp
#
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Firebase Admin SDK (for secure server-side Firestore access) ───────────────
# Required for: storing agency Twilio credentials securely, superadmin dashboard
#
# How to get:
#   1. Firebase Console → Project Settings → Service Accounts tab
#   2. Click "Generate new private key" → download JSON file
#   3. Run: node -e "console.log(Buffer.from(require('fs').readFileSync('./service-account.json')).toString('base64'))"
#   4. Paste the output below (delete the JSON file after)
#
FIREBASE_SERVICE_ACCOUNT_KEY="base64encodedserviceaccountjson"

# ── Custom Domain Routing ──────────────────────────────────────────────────────
# Your platform's root hostname (without https://)
# Used by middleware to distinguish platform traffic from agency custom domains.
NEXT_PUBLIC_PLATFORM_HOST="yourapp.vercel.app"

# Vercel API credentials — used to programmatically add/remove custom domains.
# How to get:
#   1. Vercel Dashboard → Account Settings → Tokens → Create token
#   2. Project ID: Vercel Dashboard → Project → Settings → General → Project ID
#   3. Team ID (only if your project is under a team):
#      Vercel Dashboard → Team Settings → General → Team ID
#
VERCEL_TOKEN="your_vercel_api_token"
VERCEL_PROJECT_ID="your_vercel_project_id"
VERCEL_TEAM_ID=""   # leave blank for personal accounts

# ── Firebase Cloud Messaging (Web Push Notifications) ──────────────────────────
# Required for browser push notifications when new leads are assigned to agents.
#
# How to get your VAPID key:
#   1. Go to Firebase Console → Project Settings → Cloud Messaging tab
#   2. Under "Web Push certificates", click "Generate key pair"
#   3. Copy the public key and paste it below
#
NEXT_PUBLIC_FIREBASE_VAPID_KEY="your_vapid_public_key_here"
